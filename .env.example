# Copy this file to .env and fill in secrets for local development
# cp .env.example .env

# ── Gemini AI ──────────────────────────────────────────────────────
# Google Gemini API key — server-side only. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Weather ────────────────────────────────────────────────────────
# OpenWeatherMap API key for stadium weather data (Next.js server-side)
# Get one at https://openweathermap.org/api (free tier available)
OWM_API_KEY=your_owm_api_key_here

# ── Match Feed ─────────────────────────────────────────────────────
# worldcup26.ir is a free public API — no token required for read access.
# GET /get/games, /get/teams, /get/stadiums, etc. work without authentication.
# Docs: https://worldcup26.ir/api-docs/
# WORLDCUP26_TOKEN is no longer needed.
